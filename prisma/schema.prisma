// =============================================================
//  Prisma schema — SUBSET untuk modul Booking.
//  Hasil yang Anda dapat dari `prisma db pull` akan berisi SELURUH
//  45 tabel. Di sini hanya ditampilkan model + enum yang relevan
//  dengan modul Booking agar kode di src/ ter-grounded & compile.
//  Nama model = nama tabel, field = snake_case (default introspeksi).
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ENUMS (dari schema SQL) ----------
enum booking_type {
  insidentil
  abonemen
}

enum booking_status {
  pending
  confirmed
  checked_in
  completed
  cancelled
  no_show
}

enum court_type {
  paddle
  badminton
  tennis
  basketball
  futsal
  other
}

enum abonemen_status {
  active
  expired
  cancelled
}

enum waiting_status {
  waiting
  notified
  booked
  expired
  cancelled
}

// ---------- MODELS ----------
// users — field auth ditambahkan untuk modul Authentication (real JWT).
model users {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email             String            @unique @db.VarChar(255)
  phone             String            @unique @db.VarChar(20)
  full_name         String            @db.VarChar(150)
  password_hash     String
  role              user_role         @default(member)
  is_active         Boolean           @default(true)
  email_verified    Boolean           @default(false)
  email_verified_at DateTime?         @db.Timestamptz(6)
  referral_code     String?           @unique @db.VarChar(20)
  referred_by       String?           @db.Uuid
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @db.Timestamptz(6)

  referrer          users?            @relation("UserReferral", fields: [referred_by], references: [id], onDelete: SetNull)
  referrals         users[]           @relation("UserReferral")
  bookings          bookings[]
  waiting_list      waiting_list[]
  user_abonemen     user_abonemen[]
  sessions          sessions[]
  password_resets   password_resets[]
  payments          payments[]
  user_memberships  user_memberships[]
  pool_tickets      pool_tickets[]
  tickets             tickets[]
  ticket_scans        ticket_usage[]        @relation("TicketScans")
  event_registrations event_registrations[]
  reviews             reviews[]
  loyalty_points      loyalty_points?
  points_transactions points_transactions[]
  notifications       notifications[]
  push_tokens         push_tokens[]
  email_logs          email_logs[]
  staff               staff?
  inventory_logs      inventory_logs[]      @relation("InventoryCreatedBy")
}

enum user_role {
  member
  admin
  staff
  finance
  superadmin
}

model sessions {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String   @db.Uuid
  refresh_token String   @unique
  ip_address    String?  @db.Inet
  user_agent    String?
  device_info   Json?
  is_revoked    Boolean  @default(false)
  expired_at    DateTime @db.Timestamptz(6)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model password_resets {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique
  expired_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model courts {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name           String           @db.VarChar(100)
  code           String           @unique @db.VarChar(20)
  type           court_type       @default(paddle)
  price_per_hour Decimal          @db.Decimal(12, 2)
  capacity       Int              @default(4)
  is_indoor      Boolean          @default(true)
  facilities     Json             @default("[]")
  image_url      String?
  description    String?
  is_active      Boolean          @default(true)
  sort_order     Int              @default(0)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)

  court_schedules court_schedules[]
  bookings        bookings[]
  waiting_list    waiting_list[]
  occupancy_logs  occupancy_logs[]
}

model court_schedules {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  court_id          String   @db.Uuid
  day_of_week       Int      @db.SmallInt
  open_time         DateTime @db.Time(6)
  close_time        DateTime @db.Time(6)
  is_holiday_closed Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  courts courts @relation(fields: [court_id], references: [id], onDelete: Cascade)

  @@unique([court_id, day_of_week])
}

model abonemen_packages {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String          @db.VarChar(100)
  description       String?
  sessions_per_week Int
  duration_weeks    Int
  price             Decimal         @db.Decimal(12, 2)
  valid_courts      Json            @default("[]")
  is_active         Boolean         @default(true)
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @default(now()) @db.Timestamptz(6)

  user_abonemen     user_abonemen[]
}

model user_abonemen {
  id                 String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String            @db.Uuid
  package_id         String            @db.Uuid
  start_date         DateTime          @db.Date
  end_date           DateTime          @db.Date
  remaining_sessions Int
  status             abonemen_status   @default(active)
  notes              String?
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @db.Timestamptz(6)

  users             users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  abonemen_packages abonemen_packages @relation(fields: [package_id], references: [id])
  bookings          bookings[]
}

model bookings {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String         @db.Uuid
  court_id            String         @db.Uuid
  abonemen_id         String?        @db.Uuid
  booking_type        booking_type   @default(insidentil)
  booking_date        DateTime       @db.Date
  start_time          DateTime       @db.Time(6)
  end_time            DateTime       @db.Time(6)
  duration_hours      Decimal        @db.Decimal(4, 2)
  total_price         Decimal        @default(0) @db.Decimal(12, 2)
  status              booking_status @default(pending)
  notes               String?
  checked_in_at       DateTime?      @db.Timestamptz(6)
  cancelled_at        DateTime?      @db.Timestamptz(6)
  cancellation_reason String?
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime       @default(now()) @db.Timestamptz(6)

  users         users          @relation(fields: [user_id], references: [id])
  courts        courts         @relation(fields: [court_id], references: [id])
  user_abonemen user_abonemen? @relation(fields: [abonemen_id], references: [id], onDelete: SetNull)
  occupancy_logs occupancy_logs[]

  @@index([user_id])
  @@index([court_id])
  @@index([booking_date])
  @@index([status])
  @@index([court_id, booking_date, status])
}

model waiting_list {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String         @db.Uuid
  court_id        String         @db.Uuid
  preferred_date  DateTime       @db.Date
  preferred_start DateTime       @db.Time(6)
  preferred_end   DateTime       @db.Time(6)
  status          waiting_status @default(waiting)
  notified_at     DateTime?      @db.Timestamptz(6)
  expired_at      DateTime?      @db.Timestamptz(6)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)

  users  users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  courts courts @relation(fields: [court_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([court_id, preferred_date, status])
}

model site_settings {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?
  group_name  String   @default("general") @db.VarChar(80)
  updated_by  String?  @db.Uuid
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
}

// =============================================================
//  MODUL PAYMENT (dummy / lokal)
// =============================================================

enum payment_status {
  pending
  paid
  failed
  expired
  refunded
  partial_refund
}

enum payment_method_type {
  bank_transfer
  qris
  credit_card
  debit_card
  ewallet
  cash
}

enum item_type {
  booking
  membership
  pool_ticket
  ticket
  event
  product
  abonemen
}

model payment_methods {
  id          String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String              @db.VarChar(100)
  code        String              @unique @db.VarChar(50)
  provider    String?             @db.VarChar(100)
  type        payment_method_type
  logo_url    String?
  fee_percent Decimal             @default(0) @db.Decimal(5, 2)
  fee_flat    Decimal             @default(0) @db.Decimal(12, 2)
  is_active   Boolean             @default(true)
  sort_order  Int                 @default(0)
  created_at  DateTime            @default(now()) @db.Timestamptz(6)
  updated_at  DateTime            @default(now()) @db.Timestamptz(6)

  payments payments[]
}

model payments {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String         @db.Uuid
  promo_id          String?        @db.Uuid
  payment_method_id String?        @db.Uuid
  amount            Decimal        @db.Decimal(12, 2)
  discount_amount   Decimal        @default(0) @db.Decimal(12, 2)
  fee_amount        Decimal        @default(0) @db.Decimal(12, 2)
  final_amount      Decimal        @db.Decimal(12, 2)
  status            payment_status @default(pending)
  reference_id      String?        @unique @db.VarChar(100)
  gateway_response  Json?
  refund_amount     Decimal        @default(0) @db.Decimal(12, 2)
  refunded_at       DateTime?      @db.Timestamptz(6)
  refund_notes      String?
  paid_at           DateTime?      @db.Timestamptz(6)
  expired_at        DateTime?      @db.Timestamptz(6)
  idempotency_key   String?        @unique @db.VarChar(100)
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @default(now()) @db.Timestamptz(6)

  users           users            @relation(fields: [user_id], references: [id])
  payment_methods payment_methods? @relation(fields: [payment_method_id], references: [id], onDelete: SetNull)
  promos          promos?          @relation(fields: [promo_id], references: [id], onDelete: SetNull)
  payment_items   payment_items[]
  invoices        invoices?

  @@index([user_id])
  @@index([status])
  @@index([reference_id])
}

model payment_items {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  payment_id String    @db.Uuid
  item_type  item_type
  item_id    String    @db.Uuid
  item_name  String    @db.VarChar(200)
  quantity   Int       @default(1)
  unit_price Decimal   @db.Decimal(12, 2)
  subtotal   Decimal   @db.Decimal(12, 2)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  payments payments @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@index([payment_id])
  @@index([item_type, item_id])
}

model invoices {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  payment_id     String   @unique @db.Uuid
  invoice_number String   @unique @db.VarChar(50)
  issued_at      DateTime @default(now()) @db.Timestamptz(6)
  pdf_url        String?
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  payments payments @relation(fields: [payment_id], references: [id], onDelete: Cascade)
}

// =============================================================
//  MODUL MEMBERSHIP
// =============================================================

enum membership_status {
  active
  expired
  cancelled
  pending
}

model membership_plans {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String   @db.VarChar(100)
  slug               String   @unique @db.VarChar(120)
  description        String?
  price              Decimal  @db.Decimal(12, 2)
  duration_days      Int
  max_bookings_month Int      @default(0)
  discount_percent   Decimal  @default(0) @db.Decimal(5, 2)
  benefits           Json     @default("[]")
  is_active          Boolean  @default(true)
  sort_order         Int      @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)

  user_memberships user_memberships[]
}

model user_memberships {
  id         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String            @db.Uuid
  plan_id    String            @db.Uuid
  start_date DateTime          @db.Date
  end_date   DateTime          @db.Date
  status     membership_status @default(pending)
  auto_renew Boolean           @default(false)
  notes      String?
  created_at DateTime          @default(now()) @db.Timestamptz(6)
  updated_at DateTime          @default(now()) @db.Timestamptz(6)

  users            users            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  membership_plans membership_plans @relation(fields: [plan_id], references: [id])

  @@index([user_id])
}

// =============================================================
//  MODUL POOL (kolam renang)
// =============================================================

enum pool_session_status {
  open
  full
  closed
  cancelled
}

enum pool_ticket_status {
  active
  used
  cancelled
  expired
}

model pool_sessions {
  id           String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String              @db.VarChar(150)
  session_date DateTime            @db.Date
  start_time   DateTime            @db.Time(6)
  end_time     DateTime            @db.Time(6)
  capacity     Int
  booked_count Int                 @default(0)
  status       pool_session_status @default(open)
  notes        String?
  created_at   DateTime            @default(now()) @db.Timestamptz(6)
  updated_at   DateTime            @default(now()) @db.Timestamptz(6)

  pool_tickets pool_tickets[]
}

model pool_ticket_types {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(100)
  price      Decimal  @db.Decimal(12, 2)
  age_min    Int      @default(0)
  age_max    Int      @default(99)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  pool_tickets pool_tickets[]
}

model pool_tickets {
  id             String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String             @db.Uuid
  session_id     String             @db.Uuid
  ticket_type_id String             @db.Uuid
  quantity       Int                @default(1)
  unit_price     Decimal            @db.Decimal(12, 2)
  total_price    Decimal            @db.Decimal(12, 2)
  qr_code        String             @unique
  status         pool_ticket_status @default(active)
  used_at        DateTime?          @db.Timestamptz(6)
  cancelled_at   DateTime?          @db.Timestamptz(6)
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  updated_at     DateTime           @default(now()) @db.Timestamptz(6)

  users             users             @relation(fields: [user_id], references: [id])
  pool_sessions     pool_sessions     @relation(fields: [session_id], references: [id])
  pool_ticket_types pool_ticket_types @relation(fields: [ticket_type_id], references: [id])

  @@index([user_id])
  @@index([session_id])
  @@index([qr_code])
}

// =============================================================
//  MODUL TICKETS / HTM
// =============================================================

enum ticket_status {
  active
  used
  cancelled
  expired
}

model ticket_categories {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @db.VarChar(150)
  description String?
  price       Decimal  @db.Decimal(12, 2)
  quota       Int
  sold_count  Int      @default(0)
  valid_from  DateTime @db.Date
  valid_until DateTime @db.Date
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  tickets tickets[]
}

model tickets {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String        @db.Uuid
  category_id   String        @db.Uuid
  quantity      Int           @default(1)
  unit_price    Decimal       @db.Decimal(12, 2)
  total_price   Decimal       @db.Decimal(12, 2)
  qr_code       String        @unique
  status        ticket_status @default(active)
  purchase_date DateTime      @default(now()) @db.Timestamptz(6)
  expired_at    DateTime?     @db.Timestamptz(6)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)

  users             users             @relation(fields: [user_id], references: [id])
  ticket_categories ticket_categories @relation(fields: [category_id], references: [id])
  ticket_usage      ticket_usage[]

  @@index([user_id])
  @@index([category_id])
  @@index([qr_code])
  @@index([status])
}

model ticket_usage {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ticket_id  String   @db.Uuid
  used_at    DateTime @default(now()) @db.Timestamptz(6)
  scanned_by String?  @db.Uuid
  location   String?  @db.VarChar(100)
  notes      String?

  tickets tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  users   users?  @relation("TicketScans", fields: [scanned_by], references: [id], onDelete: SetNull)
}

// =============================================================
//  MODUL EVENTS
// =============================================================

enum event_status {
  draft
  published
  ongoing
  completed
  cancelled
}

enum event_reg_status {
  registered
  confirmed
  checked_in
  cancelled
  waitlisted
}

model event_categories {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique @db.VarChar(120)
  color      String?  @default("#6366f1") @db.VarChar(7)
  icon       String?  @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  events events[]
}

model events {
  id                    String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  category_id           String       @db.Uuid
  title                 String       @db.VarChar(200)
  slug                  String       @unique @db.VarChar(250)
  description           String?
  banner_url            String?
  event_date            DateTime     @db.Timestamptz(6)
  end_date              DateTime?    @db.Timestamptz(6)
  location              String?      @db.VarChar(200)
  quota                 Int
  registered_count      Int          @default(0)
  price                 Decimal      @default(0) @db.Decimal(12, 2)
  organizer_name        String?      @db.VarChar(150)
  min_participants      Int          @default(1)
  registration_deadline DateTime?    @db.Timestamptz(6)
  status                event_status @default(draft)
  created_at            DateTime     @default(now()) @db.Timestamptz(6)
  updated_at            DateTime     @default(now()) @db.Timestamptz(6)

  event_categories    event_categories      @relation(fields: [category_id], references: [id])
  event_registrations event_registrations[]

  @@index([category_id])
  @@index([event_date])
  @@index([status])
  @@index([slug])
}

model event_registrations {
  id            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String           @db.Uuid
  event_id      String           @db.Uuid
  registered_at DateTime         @default(now()) @db.Timestamptz(6)
  status        event_reg_status @default(registered)
  check_in_at   DateTime?        @db.Timestamptz(6)
  qr_code       String           @unique
  notes         String?
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @default(now()) @db.Timestamptz(6)

  users  users  @relation(fields: [user_id], references: [id])
  events events @relation(fields: [event_id], references: [id])

  @@unique([user_id, event_id])
  @@index([user_id])
  @@index([event_id])
  @@index([qr_code])
}

// =============================================================
//  MODUL PROMO & LOYALTY
// =============================================================

enum promo_type {
  percentage
  fixed_amount
  free_item
}

enum points_tx_type {
  earn
  redeem
  expire
  adjustment
}

model promos {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code           String      @unique @db.VarChar(50)
  name           String      @db.VarChar(150)
  description    String?
  type           promo_type  @default(percentage)
  discount_value Decimal     @db.Decimal(12, 2)
  min_purchase   Decimal     @default(0) @db.Decimal(12, 2)
  max_discount   Decimal?    @db.Decimal(12, 2)
  quota          Int         @default(1)
  used_count     Int         @default(0)
  applicable_to  Json        @default("[\"all\"]")
  valid_from     DateTime    @db.Timestamptz(6)
  valid_until    DateTime    @db.Timestamptz(6)
  is_active      Boolean     @default(true)
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime    @default(now()) @db.Timestamptz(6)

  payments payments[]
}

model reviews {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  item_type    item_type
  item_id      String    @db.Uuid
  rating       Int       @db.SmallInt
  comment      String?
  is_published Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, item_type, item_id])
  @@index([item_type, item_id])
}

model loyalty_points {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String   @unique @db.Uuid
  total_points   Int      @default(0)
  used_points    Int      @default(0)
  expired_points Int      @default(0)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model points_transactions {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String         @db.Uuid
  type        points_tx_type
  points      Int
  balance     Int
  description String
  ref_type    item_type?
  ref_id      String?        @db.Uuid
  expired_at  DateTime?      @db.Timestamptz(6)
  created_at  DateTime       @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
}

// =============================================================
//  FASE C — OPERASIONAL
// =============================================================

enum notification_type {
  booking
  payment
  membership
  event
  promo
  system
  reminder
}

enum email_status {
  pending
  sent
  failed
  bounced
}

enum staff_role {
  cashier
  instructor
  security
  maintenance
  manager
}

enum cms_status {
  draft
  published
  archived
}

// ---- Notifications ----
model notifications {
  id         String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String            @db.Uuid
  title      String            @db.VarChar(200)
  body       String
  type       notification_type @default(system)
  is_read    Boolean           @default(false)
  read_at    DateTime?         @db.Timestamptz(6)
  action_url String?
  image_url  String?
  metadata   Json?
  created_at DateTime          @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, is_read])
  @@index([created_at])
}

model push_tokens {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  platform   String   @db.VarChar(20)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model email_logs {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?      @db.Uuid
  to_email   String       @db.VarChar(255)
  subject    String       @db.VarChar(300)
  template   String?      @db.VarChar(100)
  status     email_status @default(pending)
  error_msg  String?
  sent_at    DateTime?    @db.Timestamptz(6)
  created_at DateTime     @default(now()) @db.Timestamptz(6)

  users users? @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

// ---- Staff ----
model staff {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String     @unique @db.Uuid
  role        staff_role @default(cashier)
  employee_id String?    @unique @db.VarChar(30)
  join_date   DateTime   @db.Date
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)

  users           users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  staff_schedules staff_schedules[]
}

model staff_schedules {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  staff_id    String   @db.Uuid
  work_date   DateTime @db.Date
  shift_start DateTime @db.Time(6)
  shift_end   DateTime @db.Time(6)
  notes       String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  staff staff @relation(fields: [staff_id], references: [id], onDelete: Cascade)

  @@unique([staff_id, work_date])
}

// ---- Inventory ----
model product_categories {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique @db.VarChar(120)
  parent_id  String?  @db.Uuid
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  parent   product_categories?  @relation("CategoryTree", fields: [parent_id], references: [id], onDelete: SetNull)
  children product_categories[] @relation("CategoryTree")
  products products[]
}

model products {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  category_id String   @db.Uuid
  name        String   @db.VarChar(200)
  sku         String   @unique @db.VarChar(80)
  description String?
  price       Decimal  @db.Decimal(12, 2)
  cost_price  Decimal  @default(0) @db.Decimal(12, 2)
  stock       Int      @default(0)
  min_stock   Int      @default(5)
  image_url   String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  product_categories product_categories @relation(fields: [category_id], references: [id])
  inventory_logs     inventory_logs[]

  @@index([category_id])
}

model inventory_logs {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id   String   @db.Uuid
  type         String   @db.VarChar(20)
  quantity     Int
  stock_before Int
  stock_after  Int
  ref_type     String?  @db.VarChar(50)
  ref_id       String?  @db.Uuid
  notes        String?
  created_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  products products @relation(fields: [product_id], references: [id])
  users    users?   @relation("InventoryCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([product_id])
  @@index([created_at])
}

// ---- Reports / Analytics ----
model occupancy_logs {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  court_id    String   @db.Uuid
  log_date    DateTime @db.Date
  hour_slot   Int      @db.SmallInt
  is_occupied Boolean  @default(false)
  booking_id  String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  courts   courts    @relation(fields: [court_id], references: [id], onDelete: Cascade)
  bookings bookings? @relation(fields: [booking_id], references: [id], onDelete: SetNull)

  @@unique([court_id, log_date, hour_slot])
  @@index([court_id, log_date])
}

// ---- CMS ----
model banners {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title      String   @db.VarChar(200)
  subtitle   String?
  image_url  String
  link_url   String?
  position   String   @default("hero") @db.VarChar(50)
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  starts_at  DateTime? @db.Timestamptz(6)
  ends_at    DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model faqs {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  question   String
  answer     String
  category   String   @default("general") @db.VarChar(80)
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model galleries {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title      String?  @db.VarChar(200)
  image_url  String
  category   String   @default("facility") @db.VarChar(80)
  alt_text   String?
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model pages {
  id         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  slug       String     @unique @db.VarChar(200)
  title      String     @db.VarChar(250)
  content    String
  meta_title String?    @db.VarChar(200)
  meta_desc  String?
  status     cms_status @default(draft)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  updated_at DateTime   @default(now()) @db.Timestamptz(6)
}
