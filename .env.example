# PostgreSQL connection used by Prisma (introspeksi & runtime)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sports_facility?schema=public"

PORT=3000
NODE_ENV=development

# Auth / JWT
JWT_ACCESS_SECRET="ganti-dengan-secret-acak-min-16-char"
JWT_REFRESH_SECRET="ganti-dengan-secret-acak-lain-min-16-char"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS=7
BCRYPT_ROUNDS=10

# CORS — daftar origin frontend yang diizinkan, dipisah koma.
# Kosongkan di development untuk fallback otomatis ke http://localhost:3001.
CORS_ORIGINS="http://localhost:3001"

# Rate limiting (opsional; nilai di bawah adalah default bila tidak diset)
RATE_LIMIT_WINDOW_MS=900000   # 15 menit
RATE_LIMIT_MAX=300            # batas request per window untuk limiter global
AUTH_RATE_LIMIT_MAX=20        # batas request per window untuk endpoint auth
