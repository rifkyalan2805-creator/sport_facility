        {
          "name": "Court Availability (publik)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('today', new Date().toISOString().slice(0,10));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/courts/{{court_id}}/availability?date={{today}}",
              "host": ["{{base_url}}"],
              "path": ["courts", "{{court_id}}", "availability"],
              "query": [{ "key": "date", "value": "{{today}}" }]
            }
          }
        }
