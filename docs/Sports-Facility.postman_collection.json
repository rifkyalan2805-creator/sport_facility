    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment (booking)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.id) { pm.collectionVariables.set('payment_id', res.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"item_type\": \"booking\",\n      \"item_id\": \"{{booking_id}}\",\n      \"item_name\": \"Padel booking\",\n      \"quantity\": 1,\n      \"unit_price\": 150000\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/payments", "host": ["{{base_url}}"], "path": ["payments"] }
          }
        },
        {
          "name": "Simulate Success (DUMMY)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/payments/{{payment_id}}/simulate/success",
              "host": ["{{base_url}}"],
              "path": ["payments", "{{payment_id}}", "simulate", "success"]
            }
          }
        },
        {
          "name": "Simulate Failure (DUMMY)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Disimulasikan gagal\"\n}" },
            "url": {
              "raw": "{{base_url}}/payments/{{payment_id}}/simulate/failure",
              "host": ["{{base_url}}"],
              "path": ["payments", "{{payment_id}}", "simulate", "failure"]
